<?xml version="1.0" encoding="UTF-8"?>
<!-- Managed by Ansible (tomcat_hardening role). CIS Tomcat Benchmark. -->
<Server port="{{ tomcat_hardening_shutdown_port }}"
        shutdown="{{ tomcat_hardening_shutdown_command }}">

  <Listener className="org.apache.catalina.startup.VersionLoggerListener" />
  <Listener className="org.apache.catalina.core.AprLifecycleListener" SSLEngine="on" />
  <Listener className="org.apache.catalina.core.JreMemoryLeakPreventionListener" />
  <Listener className="org.apache.catalina.mbeans.GlobalResourcesLifecycleListener" />
  <Listener className="org.apache.catalina.core.ThreadLocalLeakPreventionListener" />

  <Service name="Catalina">

    <!-- HTTP Connector -->
    <Connector port="{{ tomcat_hardening_http_port }}"
               protocol="HTTP/1.1"
               connectionTimeout="{{ tomcat_hardening_connection_timeout }}"
               maxThreads="{{ tomcat_hardening_max_threads }}"
               maxConnections="{{ tomcat_hardening_max_connections }}"
               acceptCount="{{ tomcat_hardening_accept_count }}"
               allowTrace="{{ tomcat_hardening_allow_trace | lower }}"
               server=" "
               redirectPort="{{ tomcat_hardening_https_port }}"
{% if tomcat_hardening_http2_enabled %}
               scheme="https" />
{% else %}
               />
{% endif %}

{% if tomcat_hardening_ssl_enabled %}
    <!-- HTTPS Connector -->
    <Connector port="{{ tomcat_hardening_https_port }}"
               protocol="org.apache.coyote.http11.Http11NioProtocol"
               SSLEnabled="true"
               maxThreads="{{ tomcat_hardening_max_threads }}"
               connectionTimeout="{{ tomcat_hardening_connection_timeout }}"
               allowTrace="{{ tomcat_hardening_allow_trace | lower }}"
               server=" ">
      <SSLHostConfig protocols="{{ tomcat_hardening_ssl_protocol }}"
                     ciphers="{{ tomcat_hardening_ssl_ciphers | replace('\n', ',') | trim }}">
        <Certificate certificateFile="{{ tomcat_hardening_ssl_certificate_file }}"
                     certificateKeyFile="{{ tomcat_hardening_ssl_certificate_key_file }}" />
      </SSLHostConfig>
    </Connector>
{% endif %}

{% if not tomcat_hardening_ajp_enabled %}
    <!-- AJP disabled — CVE-2020-1938 (Ghostcat) mitigation -->
{% else %}
    <Connector protocol="AJP/1.3" port="{{ tomcat_hardening_ajp_port }}"
               redirectPort="{{ tomcat_hardening_https_port }}" secret="CHANGEME" />
{% endif %}

    <Engine name="Catalina" defaultHost="localhost">
      <Host name="localhost" appBase="webapps" unpackWARs="true" autoDeploy="false">

{% if tomcat_hardening_access_log_enabled %}
        <Valve className="org.apache.catalina.valves.AccessLogValve"
               directory="logs"
               prefix="localhost_access_log"
               suffix=".txt"
               pattern="{{ tomcat_hardening_access_log_pattern }}"
               rotatable="{{ tomcat_hardening_rotate_logs | lower }}" />
{% endif %}

        <Valve className="org.apache.catalina.valves.RemoteIpValve" />

      </Host>
    </Engine>
  </Service>
</Server>
