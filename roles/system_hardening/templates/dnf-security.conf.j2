# /etc/dnf/dnf.conf — security section managed by Ansible (system_hardening role)
# Enforce GPG verification. CIS Benchmark: 1.2.x
[main]
gpgcheck={{ 1 if system_hardening_dnf_gpgcheck else 0 }}
repo_gpgcheck={{ 1 if system_hardening_dnf_repo_gpgcheck else 0 }}
localpkg_gpgcheck={{ 1 if system_hardening_dnf_localpkg_gpgcheck else 0 }}
installonly_limit=3
clean_requirements_on_remove=True
